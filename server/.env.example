# ─── Server Environment Variables ─────────────────────────────

# MongoDB connection string
# Local:   mongodb://127.0.0.1:27017/edusync-ai
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/edusync-ai
MONGO_URI=mongodb://127.0.0.1:27017/edusync-ai

# JWT secret key (use a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key

# Groq API key for AI features
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# Server port (platforms like Render set this automatically)
PORT=5000

# Node environment
NODE_ENV=development

# Comma-separated list of allowed frontend origins for CORS
# Example: https://edusync.vercel.app,https://edusync-staging.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
